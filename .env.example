# Leash — M1 backend env
# Copy to .env and fill in. Never commit the real .env.

# ---------- XRPL ----------
# Testnet WebSocket
XRPL_RPC=wss://s.altnet.rippletest.net:51233

# Network id (xrpl:1 = testnet, xrpl:0 = mainnet — DO NOT use mainnet)
XRPL_NETWORK=xrpl:1

# The MERCHANT (payee) wallet — the demo's stand-in paid service. In the real
# product the merchant address is NOT set here; it arrives dynamically in each
# merchant's 402 challenge. Leave blank on first run to auto-fund from the
# testnet faucet (the seed + address are printed; save the seed for re-runs).
XRPL_MERCHANT_SEED=

# The AGENT (payer) wallet — funds the payments. Same first-run pattern.
XRPL_AGENT_SEED=

# ---------- Leash platform fee ----------
# Where Leash collects its cut. Paid as a SEPARATE on-chain tx, on top of the
# merchant price, every payment. Leave blank to disable the fee entirely.
# (Legacy XRPL_PAY_TO is still read as a fallback.)
LEASH_FEE_WALLET=
# Fee rate in basis points. 1000 = 10%, 250 = 2.5%. Default 1000.
LEASH_FEE_BPS=1000

# ---------- pricing (USD is the unit of account) ----------
# Per-call price in USD cents. 1 = $0.01. Policy gates on this; on-chain settle
# amount is derived per asset (XRP via the rate below, stablecoins 1:1).
PRICE_USD_CENTS=1
# XRP→USD rate. XRP amounts convert via this; stablecoins are 1:1 with USD.
XRP_USD_RATE=2.5

# ---------- Stablecoin issuers (XRPL issued currencies) ----------
# Set an issuer to enable LIVE settlement in that token (the agent wallet also
# needs a trust line + balance). Blank → the token is demo-only (simulated in
# Money=Demo; a clear error in Money=Live).
XRPL_USDC_ISSUER=
XRPL_USDT_ISSUER=
XRPL_RLUSD_ISSUER=

# ---------- merchant HTTP ----------
PORT=8080

# ---------- policy engine (USD cents) ----------
POLICY_TOTAL_BUDGET_USD_CENTS=5000        # $50 lifetime allowance
POLICY_PER_TX_CAP_USD_CENTS=50            # $0.50 per single payment (max/block)
POLICY_DAILY_CAP_USD_CENTS=500            # $5 per day
POLICY_APPROVAL_THRESHOLD_USD_CENTS=25    # ≤ $0.25 auto-pays; above → Approve/Deny

# ---------- agent ----------
AGENT_QUERY=compare AI coding tools 2026

# ---------- Web app (M2) ----------
# Port for the web frontend + SSE backend. Open http://localhost:$WEB_PORT in
# your browser after `npm run web`. Same value as PORT by default — the M1
# merchant + the M2 web UI share the same Express app.
WEB_PORT=8080

# ---------- Multi-chain (Approach A) ----------
# Comma-separated chain ids the control plane may route to. Only chains with an
# implemented adapter (src/chains/<id>.ts) AND listed here are selectable.
# Live: xrpl. Scaffolded stubs: solana, base, ethereum — implement + add here.
CHAINS_ENABLED=xrpl
DEFAULT_CHAIN=xrpl

# ---------- AI model gateway ("AI tokens") ----------
# One OpenRouter key → every model. The user always chooses the model in the UI;
# the app never picks one. Leave OPENROUTER_API_KEY blank to run pure BYOK.
AI_GATEWAY=openrouter
OPENROUTER_API_KEY=
AI_MARKUP_BPS=2000                      # 2000 bps = 20% markup on inference

# ---------- Prepaid credits (non-custodial AI billing) ----------
# Off by default → BYOK mode. Turn on to meter AI spend from a USD balance.
CREDITS_ENABLED=false
CREDIT_USD_CENTS=1                      # 1 credit = $0.01
CREDITS_SEED_USD_CENTS=500             # demo starting balance: $5.00

# ---------- Funding: credit line (governed by the policy engine) ----------
# Demo credit line the agent can spend instead of its own wallet.
CREDIT_LINE_USD_CENTS=2500              # $25 credit line
